# Cursor API キー（https://cursor.com/dashboard/integrations で取得）
CURSOR_API_KEY=your_api_key_here

# 使用モデル（composer-2 が最も低コスト。失敗時は CURSOR_FALLBACK_MODELS を順に試行）
CURSOR_MODEL=composer-2

# fast バリアントは高コストのため、デフォルトは false（standard）
CURSOR_MODEL_FAST=false

# フォールバックモデル（カンマ区切り、任意）
# CURSOR_FALLBACK_MODELS=

# VOICEVOX Engine の URL（デフォルト: ローカル）
VOICEVOX_URL=http://127.0.0.1:50021
